    "@ai-sdk/google": "^3.0.82",
    "ai": "^6.0.204"
  },
  "devDependencies": {
    "@types/node": "^24.10.2",
    "oxfmt": "^0.54.0",
    "oxlint": "^1.69.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "packageManager": "pnpm@10.31.0"
