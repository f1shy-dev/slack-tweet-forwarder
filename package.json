{
  "name": "slack-tweet-forwarder",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc --project tsconfig.build.json",
    "start": "node dist/index.js",
    "check": "tsc --noEmit",
    "test": "tsx --test test/**/*.test.ts",
    "lint": "oxlint .",
    "format": "oxfmt --write ."
