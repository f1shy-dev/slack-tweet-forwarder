{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "slack-tweet-forwarder",
  "main": "src/index.ts",
  "compatibility_date": "2026-06-12",
  "kv_namespaces": [
    {
      "binding": "DEDUPE_KV",
      "id": "b40cb9ebab974da39c184d3a085d8476",
    },
  ],
  "secrets": {
    "required": [
      "X_CONSUMER_SECRET",
      "X_BEARER_TOKEN",
      "SLACK_WEBHOOK_URL",
      "GOOGLE_GENERATIVE_AI_API_KEY",
    ],
  },
}
